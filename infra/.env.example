# Global Config
AWS_REGION=us-east-2
PROJECT_NAME=poc-strands-agents-ts
AGENT_RUNTIME_ARN=arn:aws:lambda:us-east-2:123456789012:function:agent-runtime

# Custom Setup (are not been used yet...)
# ── Agent Auth Mode (JWT | SIGV4) ───────────────────────────────────────────────
# JWT:   Frontend authenticates using Cognito JWTs (requires Cognito setup)
# SIGV4: Frontend uses AWS SigV4 to authenticate directly with AgentCore (no Cognito required)
AGENT_AUTH_MODE="" # JWT | SIGV4 - defaults to `JWT`

# ── Frontend Agent Mode ────────────────────────────────────────────────────────
# "bff"    → calls BFF proxy (default, no auth required)
# "direct" → calls AgentCore directly (requires Cognito + ARN below)
FRONTEND_AGENT_MODE="" # direct | bff - defaults to `direct`