# Global Config
AWS_REGION=us-east-1
PROJECT_NAME=demo-strands-agents-ts

# Additional setup options
# ── Agent Auth Mode (JWT | SIGV4) ───────────────────────────────────────────────
# JWT:   AgentCore runtime validates Cognito-issued JWTs
# SIGV4: AgentCore runtime expects SigV4 invocation
AGENT_AUTH_MODE="JWT" # JWT | SIGV4 - defaults to `JWT`

# Agent image platform used by the CDK Docker asset.
# Default is linux/arm64 to match the Bedrock AgentCore runtime target.
# On non-arm64 machines, install emulation first:
#   npm run docker:setup-arm64
# You can also set this to linux/amd64 or current for local troubleshooting.
AGENT_IMAGE_PLATFORM="linux/arm64"