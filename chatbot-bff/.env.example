
PORT=3001
AWS_REGION=us-east-1
ALLOWED_ORIGIN=*
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:YOUR_ACCOUNT_ID:runtime/my-agent-service-XXXXXXXXXX
# NODE_TLS_REJECT_UNAUTHORIZED=0 # Local development only - allows self-signed certificates

# Auth mode: jwt (Cognito SRP) or sigv4 (IAM credentials), default is jwt
INVOKE_AUTH_MODE=jwt
# When INVOKE_AUTH_MODE=jwt, set the following:
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_USERNAME=
COGNITO_PASSWORD=
